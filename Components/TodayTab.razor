@inject AppStateService State

@{ var streak = State.GetStreak(); }

@if (State.Percentage == 0 && !_editMode)
{
    <div class="card" style="font-size:14px;line-height:1.6">
        <div style="font-weight:600;color:#e6edf3;margin-bottom:6px">New day, clean slate.</div>
        <div style="color:#8b949e">
            Start with your spiritual practice. Hit 70%+ and the day counts toward your streak.
            Remember: if you feel the pull to game — do the startup ritual. Just 5 minutes.
            @(streak == 0 ? " Let's start building." : $" You're at {streak} days — keep collecting.")
        </div>
    </div>
}

<!-- Edit mode toggle -->
<div style="display:flex;justify-content:flex-end;margin-bottom:8px">
    <button class="reset-btn" style="font-size:11px" @onclick="() => _editMode = !_editMode">
        @(_editMode ? "✓ Done editing" : "✎ Edit anchors")
    </button>
</div>

@foreach (var group in State.ActiveAnchors.GroupBy(a => a.Group))
{
    <div class="mono label" style="color:#8b949e;margin-top:16px">@group.Key</div>
    @foreach (var anchor in group)
    {
        var isChecked = State.Checks.GetValueOrDefault(anchor.Id);
        <div style="display:flex;align-items:center;gap:4px">
            <button class="anchor @(isChecked ? "done" : "")" style="flex:1" @onclick="async () => { await State.ToggleAnchorAsync(anchor.Id); StateHasChanged(); }">
                <div class="check @(isChecked ? "checked" : "")">@(isChecked ? "✓" : "")</div>
                <span class="anchor-label">@anchor.Icon @anchor.Label</span>
            </button>
            @if (_editMode)
            {
                <button class="task-del" style="padding:8px" @onclick="async () => { await State.RemoveAnchorAsync(anchor.Id); StateHasChanged(); }">×</button>
            }
        </div>
    }
}

@if (_editMode)
{
    <div class="card" style="margin-top:16px">
        <div class="mono label" style="color:#5bbfdf;padding-left:0;margin-bottom:8px">ADD NEW ANCHOR</div>
        <div style="display:flex;flex-direction:column;gap:8px">
            <input type="text" @bind="_newIcon" placeholder="🔥" maxlength="2" class="task-input" style="width:50px;text-align:center;font-size:18px" />
            <input type="text" @bind="_newLabel" placeholder="Anchor label..." class="task-input" />
            <select @bind="_newGroup" class="task-select" style="width:100%">
                @foreach (var g in _groups)
                {
                    <option value="@g">@g</option>
                }
            </select>
            <button class="task-add-btn" @onclick="AddAnchor">+ Add Anchor</button>
        </div>
    </div>
}

<div class="mono label" style="color:#8b949e;margin-top:24px">TODAY'S NOTE</div>
<textarea class="note-input" placeholder="How did today feel? What went well? What needs adjusting?"
          value="@State.Note"
          @oninput="async (e) => { await State.SaveNoteAsync(e.Value?.ToString() ?? string.Empty); }">@State.Note</textarea>

@code {
    private bool _editMode;
    private string _newLabel = "";
    private string _newIcon = "";
    private string _newGroup = "Spiritual Practice";

    private readonly string[] _groups = {
        "Spiritual Practice", "BMW — Water", "BMW — Move", "Energy Collection",
        "Nutrition", "Dream Project", "Guitar", "Planning & Growth", "Home", "Discipline"
    };

    private async Task AddAnchor()
    {
        if (string.IsNullOrWhiteSpace(_newLabel)) return;
        await State.AddAnchorAsync(_newLabel.Trim(), _newGroup, string.IsNullOrWhiteSpace(_newIcon) ? "•" : _newIcon.Trim());
        _newLabel = "";
        _newIcon = "";
        StateHasChanged();
    }
}
