<div class="card" style="font-size:13px;color:#8b949e;line-height:1.6">
    <div style="font-weight:600;color:#e6edf3;margin-bottom:4px">Less Is More — Eat Like You Mean It</div>
    Your body doesn't need volume, it needs density. Two focused meals beat three mediocre ones.
    Ancestral whole foods, cooked at home, nothing your great-grandmother wouldn't recognize.
</div>

<div class="mono label" style="color:#5bbfdf;margin-top:20px">MEAL TIMING — WHAT TO EAT WHEN</div>
@foreach (var m in AppData.MealTiming)
{
    <div class="card" style="margin-bottom:6px">
        <div style="font-size:14px;font-weight:600;color:#5bbfdf;margin-bottom:6px">@m.Meal</div>
        <div style="font-size:13px;color:#c9d1d9;margin-bottom:6px;line-height:1.6">@m.Items</div>
        @if (!string.IsNullOrEmpty(m.Prep))
        {
            <div style="font-size:12px;color:#df8b5b;line-height:1.5">@m.Prep</div>
        }
    </div>
}

<div class="mono label" style="color:#5bdf8b;margin-top:24px">DAILY MACROS</div>
@foreach (var m in AppData.Macros)
{
    <div class="card" style="margin-bottom:6px">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
            <span style="font-size:15px;font-weight:600;color:#e6edf3">@m.Nutrient</span>
            <span class="mono" style="font-size:13px;color:#5bdf8b;font-weight:600">@m.Target</span>
        </div>
        <div style="font-size:13px;color:#8b949e;margin-bottom:6px">@m.Why</div>
        <div style="font-size:12px;color:#5bbfdf">Best sources: @m.Sources</div>
    </div>
}

<div class="mono label" style="color:#df8b5b;margin-top:24px">ESSENTIAL NUTRIENTS</div>
@foreach (var e in AppData.Essentials)
{
    var priStyle = e.Priority switch {
        "critical" => ("background:#1a3a2a;color:#5bdf8b", "#2a4a3a"),
        "high" => ("background:#2a2a1a;color:#dfdf5b", "#21262d"),
        _ => ("background:#1a1a2a;color:#8b8bdf", "#21262d")
    };
    <div class="card nut-toggle" style="cursor:pointer;margin-bottom:4px;border-color:@priStyle.Item2" @onclick="() => ToggleEssential(e.Category)">
        <div style="display:flex;justify-content:space-between;align-items:center">
            <span style="font-size:14px;font-weight:600;color:#e6edf3">@e.Category</span>
            <span class="mono" style="font-size:10px;letter-spacing:1px;padding:2px 8px;border-radius:4px;text-transform:uppercase;@priStyle.Item1">@e.Priority</span>
        </div>
        @if (expandedEssential == e.Category)
        {
            <div style="margin-top:8px;font-size:13px;color:#8b949e;line-height:1.6">@e.Items</div>
        }
    </div>
}

<div class="mono label" style="color:#df5b5b;margin-top:24px">AVOID LIST</div>
<div style="background:#1a1015;border:1px solid #3a1a2a;border-radius:10px;padding:14px">
    @foreach (var a in AppData.AvoidList)
    {
        <div style="font-size:13px;color:#c9a0a0;margin-bottom:6px;padding-left:8px;border-left:2px solid #3a1a2a;line-height:1.5">@a</div>
    }
</div>

<div class="mono label" style="color:#5bdf8b;margin-top:24px">GROUND BEEF WEEKLY ROTATION</div>
<div class="card" style="border-color:#2a4a3a">
    @foreach (var b in AppData.BeefRotation)
    {
        <div style="font-size:13px;color:#c9d1d9;margin-bottom:8px;padding-left:8px;border-left:2px solid #2a5a4a;line-height:1.6">@b</div>
    }
</div>

<div class="mono label" style="color:#df5b8b;margin-top:24px">KIDS NUTRITION</div>
<div class="card">
    @foreach (var k in AppData.KidsNutrition)
    {
        <div style="font-size:13px;color:#c9d1d9;margin-bottom:8px;padding-left:8px;border-left:2px solid #5a3a4a;line-height:1.6">@k</div>
    }
</div>

@code {
    private string? expandedEssential;

    private void ToggleEssential(string cat)
    {
        expandedEssential = expandedEssential == cat ? null : cat;
    }
}
