@page "/register"
@inject AppStateService State
@inject SupabaseService Supa
@inject NavigationManager Nav

@if (State.IsLoggedIn)
{
    <div class="loading">Redirecting...</div>
}
else
{
    <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px">
        <div style="width:100%;max-width:380px">
            <div class="mono label" style="color:#8b949e;text-align:center">DAILY OPERATING SYSTEM</div>
            <div style="text-align:center;font-size:26px;font-weight:700;color:#e6edf3;margin-bottom:24px">Claim Your Handle</div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div style="background:#2a1a1a;border:1px solid #5a2a2a;border-radius:8px;padding:10px 14px;color:#df5b5b;font-size:13px;margin-bottom:12px">@_error</div>
            }

            <div style="margin-bottom:12px">
                <div class="mono label" style="font-size:10px">USERNAME</div>
                <input type="text" @bind="_username" @bind:event="oninput"
                       placeholder="3-20 chars, letters/numbers/underscores"
                       maxlength="20" class="task-input" style="width:100%" disabled="@_submitting" />
            </div>

            <div style="margin-bottom:16px">
                <div class="mono label" style="font-size:10px">EMOJI AVATAR <span style="color:#484f58">(optional)</span></div>
                <input type="text" @bind="_emoji" placeholder="🧙‍♂️" maxlength="2"
                       class="task-input" style="width:60px;text-align:center;font-size:20px" disabled="@_submitting" />
            </div>

            <button class="task-add-btn" style="width:100%;padding:12px;font-size:14px" @onclick="DoRegister" disabled="@_submitting">
                @(_submitting ? "Creating..." : "Claim Username")
            </button>

            <div style="text-align:center;margin-top:16px;font-size:12px;color:#484f58">
                You start as <span style="color:#5bdf8b;font-weight:600">Paragon</span> — lose it forever on your first lie.
            </div>
        </div>
    </div>
}

@code {
    private string _username = "";
    private string? _emoji;
    private string? _error;
    private bool _submitting;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await State.LoadAsync();
        if (State.IsLoggedIn) Nav.NavigateTo("", forceLoad: true);
        StateHasChanged();
    }

    private async Task DoRegister()
    {
        _error = null;
        var name = _username?.Trim() ?? "";

        if (name.Length < 3) { _error = "Username must be at least 3 characters."; return; }
        if (name.Length > 20) { _error = "Username must be 20 characters or fewer."; return; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(name, @"^[a-zA-Z0-9_]+$"))
        { _error = "Only letters, numbers, and underscores."; return; }

        _submitting = true;
        StateHasChanged();

        try
        {
            if (await Supa.UsernameExists(name))
            { _error = $"\"{name}\" is taken."; _submitting = false; return; }

            var emoji = string.IsNullOrWhiteSpace(_emoji) ? null : _emoji.Trim();
            var userId = await Supa.RegisterUser(name, emoji);
            await State.LoginAsync(userId, name.ToLower(), emoji);
            Nav.NavigateTo("", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = $"Failed: {ex.Message}";
            _submitting = false;
        }
    }
}
